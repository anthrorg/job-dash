# Postgres connection string (Neon, Supabase, RDS, or local)
# e.g. postgres://user:pass@host:5432/jobdash?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jobdash

# Set true to force SSL even if the URL doesn't say sslmode=require
DATABASE_SSL=false

# Long random string used to sign session cookies. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Secret code required to register an account. If unset, registration is disabled.
INVITE_CODE=pick-something-secret

PORT=3000
NODE_ENV=development
