{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job.sylphie.live/import-schema.json",
  "title": "Job Search HQ import format",
  "description": "Paste a JSON object of this shape into the dashboard's Import box. Hand this schema to an LLM along with a job posting (or your social-post stats) and have it return matching JSON. Send any subset of the three arrays; omit ones with no items.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "apps": {
      "type": "array",
      "description": "Job applications.",
      "items": { "$ref": "#/$defs/application" }
    },
    "posts": {
      "type": "array",
      "description": "Social posts and their engagement stats.",
      "items": { "$ref": "#/$defs/post" }
    },
    "companies": {
      "type": "array",
      "description": "Shared notes about companies (employers or recruiting agencies). One note per company, matched case-insensitively by name.",
      "items": { "$ref": "#/$defs/company" }
    }
  },
  "$defs": {
    "application": {
      "type": "object",
      "required": ["company"],
      "additionalProperties": false,
      "properties": {
        "company": { "type": "string", "description": "Employer name. Required." },
        "role": { "type": "string", "description": "Job title / role." },
        "link": { "type": "string", "description": "URL of the job posting." },
        "dateApplied": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date applied (or date the recruiter reached out), YYYY-MM-DD. Defaults to today if omitted."
        },
        "origin": {
          "enum": ["self", "recruiter"],
          "default": "self",
          "description": "'self' when the candidate applied first; 'recruiter' when a recruiter reached out first (enables the Recruiter Outreach stage and makes Recruiter Screen optional)."
        },
        "stage": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Furthest stage reached: 0 Recruiter Outreach (only valid with origin 'recruiter'), 1 Applied, 2 Recruiter Screen, 3 Interview, 4 Final Round, 5 Offer. Self-applied applications are floored to 1."
        },
        "outcome": {
          "enum": ["active", "rejected", "ghosted", "withdrawn"],
          "default": "active",
          "description": "Current outcome. Use 'active' while still in play."
        },
        "notes": { "type": "string", "description": "Optional free text." },
        "recruiter": {
          "type": ["object", "null"],
          "default": null,
          "additionalProperties": false,
          "description": "Recruiter contact, or null if none.",
          "properties": {
            "name": { "type": "string" },
            "company": { "type": "string", "description": "Agency / company the recruiter works for." },
            "profile": { "type": "string", "description": "LinkedIn or other profile URL." },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "lastContacted": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Date last contacted, YYYY-MM-DD."
            }
          }
        }
      }
    },
    "post": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date posted, YYYY-MM-DD. Defaults to today if omitted."
        },
        "platform": {
          "type": "string",
          "default": "LinkedIn",
          "description": "e.g. LinkedIn, X, Mastodon."
        },
        "title": { "type": "string", "description": "Post topic or a URL. Required." },
        "impressions": { "type": "integer", "minimum": 0 },
        "reactions": { "type": "integer", "minimum": 0 },
        "comments": { "type": "integer", "minimum": 0 }
      }
    },
    "company": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "Company or agency name. Required." },
        "notes": { "type": "string", "description": "Free-text notes about this company." }
      }
    }
  },
  "examples": [
    {
      "apps": [
        {
          "company": "Acme Corp",
          "role": "Senior Engineer",
          "link": "https://acme.example.com/jobs/123",
          "dateApplied": "2026-06-09",
          "origin": "recruiter",
          "stage": 3,
          "outcome": "active",
          "notes": "Referred by a friend.",
          "recruiter": {
            "name": "Jane Doe",
            "company": "TalentCo",
            "profile": "https://linkedin.com/in/janedoe",
            "email": "jane@talentco.example.com",
            "phone": "",
            "lastContacted": "2026-06-09"
          }
        }
      ],
      "posts": [
        {
          "date": "2026-06-08",
          "platform": "LinkedIn",
          "title": "Reflections on system design interviews",
          "impressions": 3400,
          "reactions": 120,
          "comments": 18
        }
      ],
      "companies": [
        {
          "name": "Acme Corp",
          "notes": "Series C, ~400 people, platform org is hiring."
        }
      ]
    }
  ]
}
